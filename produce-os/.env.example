# All optional — without any of these, Produce OS runs on a seeded local
# demo database and a built-in rule-based parser.

# Supabase (run supabase/schema.sql first)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI order parsing (Anthropic). Model is swappable via VITE_ANTHROPIC_MODEL.
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=claude-opus-4-8
